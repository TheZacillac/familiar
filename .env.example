# Model — uses provider:model format
# Examples:
#   ollama:nemotron-3-nano:latest   (local, default)
#   openai:gpt-4o                   (requires OPENAI_API_KEY)
#   anthropic:claude-sonnet-4-20250514       (requires ANTHROPIC_API_KEY)
#   google_genai:gemini-2.5-pro     (requires GOOGLE_API_KEY)
FAMILIAR_MODEL=ollama:nemotron-3-nano:latest

# Ollama (only needed for ollama provider)
OLLAMA_BASE_URL=http://localhost:11434

# API keys (set the one matching your provider)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# LangSmith tracing (optional — pip install -e ".[tracing]")
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=familiar
